# ═════════════════════════════════════════════════════════════
#  ASMurai ⛩️ - Effetto "Scrolling 3D" (Zero sfarfallio)
# ═════════════════════════════════════════════════════════════

frame = 0

# Se scorre troppo veloce, aumenta questo numero. 
# Se scatta, diminuiscilo!
ritardo_max = 15000000 

echo "INIZIALIZZAZIONE SEQUENZA GENETICA..."

label loop_infinito

    # Calcoliamo frame MODULO 8
    q = frame / 8
    p = q * 8
    mod = frame - p

    # Disegniamo la "fetta" 1D del nostro tunnel 3D.
    # Scorrendo verso il basso velocemente, il cervello umano
    # unisce queste fette in un'immagine tridimensionale che ruota.

    if mod == 0
        echo "▓▓▓▓▓▓▓▓▓▓        \          /        ▓▓▓▓▓▓▓▓▓▓"
    end
    if mod == 1
        echo "▓▓▓▓▓▓▓▓▓▓▓        \        /        ▓▓▓▓▓▓▓▓▓▓▓"
    end
    if mod == 2
        echo "▓▓▓▓▓▓▓▓▓▓▓▓        \      /        ▓▓▓▓▓▓▓▓▓▓▓▓"
    end
    if mod == 3
        echo "▓▓▓▓▓▓▓▓▓▓▓▓▓        | == |        ▓▓▓▓▓▓▓▓▓▓▓▓▓"
    end
    if mod == 4
        echo "▓▓▓▓▓▓▓▓▓▓▓▓        /      \        ▓▓▓▓▓▓▓▓▓▓▓▓"
    end
    if mod == 5
        echo "▓▓▓▓▓▓▓▓▓▓▓        /        \        ▓▓▓▓▓▓▓▓▓▓▓"
    end
    if mod == 6
        echo "▓▓▓▓▓▓▓▓▓▓        /          \        ▓▓▓▓▓▓▓▓▓▓"
    end
    if mod == 7
        echo "▓▓▓▓▓▓▓▓▓        |  ======  |        ▓▓▓▓▓▓▓▓▓"
    end

    # Il nostro "Motore di temporizzazione" (Busy Wait)
    r = 0
    label aspetta
        r = r + 1
        goto aspetta if r < ritardo_max

    frame = frame + 1

    # Loop eterno! (Premi Ctrl+C nel terminale per fermarlo)
    goto loop_infinito